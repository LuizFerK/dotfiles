{
  "editor.tabSize": 2,
  "editor.fontFamily": "FiraCode Nerd Font Mono",
  "editor.fontLigatures": true,
  "window.zoomLevel": 1,
  "workbench.startupEditor": "none",
  "symbols.hidesExplorerArrows": false,
  "window.menuBarVisibility": "hidden",
  "window.customTitleBarVisibility": "never",
  "workbench.activityBar.location": "hidden",
  "workbench.activityBar.orientation": "vertical",
  "workbench.iconTheme": "symbols",
  "workbench.colorTheme": "OM Theme (No Italic)",
  "files.exclude": {
    "_build": true,
    ".nix-hex": true,
    ".nix-mix": true,
    ".tests_outputs": true,
    "deps": true,
    "node_modules": true,
    ".husky": true,
    ".yarn": true,
    "**/__pycache__": true,
    "instance": true,
    ".pytest_cache": true,
    ".elixir_ls": true,
    ".expert": true,
    ".lexical": true,
    "dist": true
  },
  "files.associations": {
    "*.heex": "phoenix-heex"
  },
  "[elixir]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "lexical-lsp.lexical"
  },
  "[phoenix-heex]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "lexical-lsp.lexical"
  },
  "emmet.includeLanguages": {
    "phoenix-heex": "html",
    "elixir": "html"
  },
  "tailwindCSS.includeLanguages": {
    "phoenix-heex": "html",
    "elixir": "html"
  },
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "window.titleBarStyle": "native",
  "editor.minimap.enabled": true,
  "workbench.productIconTheme": "fluent-icons",
  "git.openRepositoryInParentFolders": "always",
  "lexical.server.releasePathOverride": "/home/luiz/.config/expert",
  "antigravity.marketplaceGalleryItemURL": "https://marketplace.visualstudio.com/items",
  "antigravity.marketplaceExtensionGalleryServiceURL": "https://marketplace.visualstudio.com/_apis/public/gallery"
}